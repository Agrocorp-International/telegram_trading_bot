# ===== OANDA =====
# Create a Practice account at oanda.com, generate a Personal Access Token
# from the fxTrade web UI ("Manage API Access"), and copy your primary account ID.
OANDA_API_TOKEN=put-your-practice-token-here
OANDA_ACCOUNT_ID=101-001-xxxxxxx-001
OANDA_ENV=practice        # "practice" or "live"

# ===== Sizing =====
# EUR_USD, USD-denominated account: 1.0 = $1/pip per trade = 10,000 units.
# 0.1 = micro ($0.10/pip), 10.0 = standard ($10/pip). Backtester default is 1.0.
DOLLARS_PER_PIP=1.0

# ===== Safety =====
# Keep false for the first few days — bot will compute and DM but not submit orders.
PLACE_ORDERS=false

# ===== Telegram =====
# Create bot via @BotFather, get your user id from @userinfobot.
TELEGRAM_BOT_TOKEN=12345:put-your-token-here
TELEGRAM_USER_ID=000000000
